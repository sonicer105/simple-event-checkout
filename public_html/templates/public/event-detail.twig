{% extends "base.twig" %}
{% set show_public_nav = true %}

{% block content %}
  {% set purchase_disabled = sales_closed or base_sold_out %}
  <div class="wa-stack wa-gap-2xl">
    <wa-breadcrumb>
      <wa-breadcrumb-item href="/">Events</wa-breadcrumb-item>
      <wa-breadcrumb-item>{{ event.name }}</wa-breadcrumb-item>
    </wa-breadcrumb>

    <div class="wa-grid wa-gap-2xl" style="--min-column-size: 35ch">
      <div class="wa-stack wa-gap-xs">
        <img
          class="wa-border-radius-s"
          src="{{ event.image_path ?: '/assets/img/placeholder.png' }}"
          alt="{{ event.name }}"
          loading="lazy"
        />
        <h3 class="wa-heading-m">Description</h3>
        <wa-divider></wa-divider>
        {% if event.long_description %}
          <div class="wa-prose">{{ event.long_description|format_md }}</div>
        {% else %}
          <div class="wa-prose">{{ event.short_description }}</div>
        {% endif %}
      </div>

      <div class="wa-stack">
        <div class="wa-split">
          <h2 class="wa-heading-xl">{{ event.name }}</h2>
          {% if event.price_cents is not null and event.price_cents != 0 and variations|length == 0 %}
            <span class="wa-body-xl">${{ (event.price_cents / 100)|number_format(2, '.', ',') }}</span>
          {% endif %}
        </div>

        {% if sales_closed %}
          <wa-callout variant="warning">Online sales for this event are closed.</wa-callout>
        {% elseif base_sold_out %}
          <wa-callout variant="warning">This event is sold out.</wa-callout>
        {% endif %}

        <div class="wa-split">
          <div class="wa-cluster wa-gap-s">
            <span class="wa-caption-s">{{ event.start_time|format_dt('F j, Y \\a\\t g:i A') }}</span>
            {% if event.location %}
              <span class="wa-caption-s" aria-hidden="true">•</span>
              <span class="wa-caption-s">{{ event.location }}</span>
            {% endif %}
          </div>
        </div>

        <form method="post" action="/cart/add" class="wa-stack wa-gap-l" novalidate>
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
          <input type="hidden" name="event_id" value="{{ event.id }}" />

          {% if variations|length > 0 %}
            <wa-radio-group label="Options" name="variation_id" orientation="horizontal">
              {% for v in variations %}
                {% set avail = ticket_availability[v.id ~ ''] ?? null %}
                {% set sold_out = (avail is not null and avail <= 0) %}
                <wa-radio appearance="button" value="{{ v.id }}" {% if purchase_disabled or sold_out %}disabled{% endif %}>
                  {{ v.name }} ({{ (v.price_cents / 100)|number_format(2, '.', ',') }}){% if sold_out %} — Sold out{% endif %}
                </wa-radio>
              {% endfor %}
            </wa-radio-group>
          {% endif %}

          {% for m in modifiers %}
            {% if m.modifier_type == 'checkbox' %}
              <wa-checkbox name="modifiers[{{ m.id }}]" value="1" {% if m.is_required %}required{% endif %} {% if purchase_disabled %}disabled{% endif %}>{{ m.name }}</wa-checkbox>
            {% elseif m.modifier_type == 'select' %}
              {% set pick_text = m|modifier_pick_text %}
              <wa-select name="modifiers[{{ m.id }}]" label="{{ m.name }}" placeholder="Select…" data-modifier-name="{{ m.name }}" data-required="{{ m.is_required ? 1 : 0 }}" {% if pick_text %}hint="{{ pick_text }}"{% endif %} {% if m.is_required %}required{% endif %} {% if purchase_disabled %}disabled{% endif %}>
                {% for opt in m.options ?? [] %}
                  <wa-option value="{{ opt }}">{{ opt }}</wa-option>
                {% endfor %}
              </wa-select>
            {% elseif m.modifier_type == 'multiselect' %}
              {% set pick_text = m|modifier_pick_text %}

              <wa-select name="modifiers[{{ m.id }}][]" label="{{ m.name }}" placeholder="Select…" multiple data-modifier-name="{{ m.name }}" data-required="{{ m.is_required ? 1 : 0 }}" data-min="{{ m.min_selected ?? "" }}" data-max="{{ m.max_selected ?? "" }}" {% if m.is_required %}required{% endif %}{% if pick_text %} hint="{{ pick_text }}"{% endif %} {% if purchase_disabled %}disabled{% endif %}>
                {% for opt in m.options ?? [] %}
                  <wa-option value="{{ opt }}">{{ opt }}</wa-option>
                {% endfor %}
              </wa-select>
            {% else %}
              <wa-input name="modifiers[{{ m.id }}]" label="{{ m.name }}" {% if m.is_required %}required{% endif %} {% if purchase_disabled %}disabled{% endif %}></wa-input>
            {% endif %}
          {% endfor %}

          {% if addons|length > 0 %}
            <wa-divider></wa-divider>
            <h3 class="wa-heading-m">Add-ons</h3>
            <div class="wa-stack wa-gap-m">
              {% for a in addons %}
                {% set a_avail = addon_availability[a.id ~ ''] ?? null %}
                {% set a_sold_out = (a_avail is not null and a_avail <= 0) %}
                <wa-card class="wa-span-grid" style="padding: 14px;">
                  <div class="wa-split">
                    <div class="wa-stack wa-gap-2xs">
                      <div class="wa-split">
                        <strong>{{ a.name }}</strong>
                        {% if a.price_cents is not null and a.price_cents != 0 %}
                          <span class="wa-caption-s">${{ (a.price_cents / 100)|number_format(2, '.', ',') }}</span>
                        {% endif %}
                      </div>
                      <span class="wa-caption-s">
                        {{ a.short_description }}
                        {% if a_sold_out %}
                          <strong>Sold out</strong>
                        {% endif %}
                      </span>
                    </div>
                    <div style="width: 140px;">
                      <wa-input type="number" name="addons[{{ a.id }}]" label="Qty" value="0" min="0" {% if purchase_disabled or a_sold_out %}disabled{% endif %}></wa-input>
                    </div>
                  </div>
                </wa-card>
              {% endfor %}
            </div>
          {% endif %}

          <wa-callout id="add-to-cart-errors" variant="warning" style="display: none;"></wa-callout>

          <wa-button type="submit" variant="brand" {% if purchase_disabled %}disabled{% endif %}>
            <wa-icon slot="start" name="bag-shopping" variant="solid"></wa-icon>
            {% if sales_closed %}
              Sales Closed
            {% elseif base_sold_out %}
              Sold Out
            {% else %}
              Add to Cart
            {% endif %}
          </wa-button>


        <script type="module">
          const form = document.querySelector('form[action="/cart/add"]');
          const callout = document.getElementById('add-to-cart-errors');
          if (!form || !callout) {
            // Nothing to wire up.
          } else {
            function clearErrors() {
              callout.style.display = 'none';
              callout.textContent = '';
            }

            function parseIntOrNull(v) {
              const n = Number.parseInt(String(v ?? '').trim(), 10);
              return Number.isFinite(n) && n > 0 ? n : null;
            }

            function pickText(minSel, maxSel) {
              if (minSel != null && maxSel != null && minSel === maxSel) return `Pick ${minSel}.`;
              if (minSel != null && maxSel != null) return `Pick ${minSel}-${maxSel}.`;
              if (minSel != null) return `Pick at least ${minSel}.`;
              if (maxSel != null) return `Pick up to ${maxSel}.`;
              return '';
            }

            function validateForm() {
              const errors = [];

              // Validate select + multiselect modifiers.
              const selects = Array.from(form.querySelectorAll('wa-select[name^="modifiers["]'));
              for (const el of selects) {
                const name = el.getAttribute('data-modifier-name') || el.getAttribute('label') || 'Modifier';
                const required = (el.getAttribute('data-required') === '1');
                const isMulti = el.hasAttribute('multiple');

                if (!isMulti) {
                  const v = (el.value ?? '').toString();
                  if (required && v.trim() === '') {
                    errors.push(`${name}: Pick 1.`);
                  }
                  continue;
                }

                const raw = el.value;
                const values = Array.isArray(raw) ? raw : (raw ? [raw] : []);
                const count = values.filter(v => String(v).trim() !== '').length;

                let minSel = parseIntOrNull(el.getAttribute('data-min'));
                const maxSel = parseIntOrNull(el.getAttribute('data-max'));
                if (minSel == null && required) minSel = 1;

                if (minSel != null && count < minSel) {
                  errors.push(`${name}: ${pickText(minSel, maxSel) || `Pick at least ${minSel}.`}`);
                } else if (maxSel != null && count > maxSel) {
                  errors.push(`${name}: ${pickText(minSel, maxSel) || `Pick up to ${maxSel}.`}`);
                }
              }



              // Validate required text inputs/areas.
              const textInputs = Array.from(form.querySelectorAll('wa-input[name^="modifiers["], wa-textarea[name^="modifiers["]'));
              for (const el of textInputs) {
                if (!el.hasAttribute('required')) continue;
                const label = el.getAttribute('label') || el.getAttribute('name') || 'Field';
                const v = (el.value ?? '').toString();
                if (v.trim() === '') {
                  errors.push(`${label}: Required.`);
                }
              }

              // Validate required checkboxes.
              const checkboxes = Array.from(form.querySelectorAll('wa-checkbox[name^="modifiers["]'));
              for (const el of checkboxes) {
                if (!el.hasAttribute('required')) continue;
                const label = (el.textContent || '').trim() || el.getAttribute('name') || 'Checkbox';
                const checked = (el.checked === true) || el.hasAttribute('checked');
                if (!checked) {
                  errors.push(`${label}: Required.`);
                }
              }
              return errors;
            }

            form.addEventListener('submit', (e) => {
              clearErrors();
              const errors = validateForm();
              if (errors.length > 0) {
                e.preventDefault();
                callout.style.display = '';
                callout.innerHTML = `<strong>Please fix the following:</strong><br>` + errors.map(x => `• ${x}`).join('<br>');
                callout.scrollIntoView({ behavior: 'smooth', block: 'center' });
              }
            });

            // Any interaction clears the warnings.
            form.addEventListener('wa-change', clearErrors);
            form.addEventListener('input', clearErrors);
            form.addEventListener('change', clearErrors);
          }
        </script>

        </form>
      </div>
    </div>
  </div>
{% endblock %}
