{% extends "base.twig" %}

{% block content %}
  <div class="admin-layout">
    <div class="admin-topbar">
      <div class="admin-brand">
        <div class="admin-brand-title">Admin</div>
        <div class="admin-brand-subtitle">{{ admin.username }}</div>
      </div>

      <div class="admin-actions">
        <form method="post" action="/admin/logout">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
          <wa-button type="submit" variant="neutral">Sign out</wa-button>
        </form>
      </div>
    </div>

    <div class="admin-main">
      <nav class="admin-nav">
        <wa-card class="admin-nav-card">
          <div class="admin-nav-links">
            <wa-button href="/admin" variant="{{ active == 'dashboard' ? 'primary' : 'neutral' }}" size="s">Dashboard</wa-button>
            <wa-button href="/admin/events" variant="{{ active == 'events' ? 'primary' : 'neutral' }}" size="s">Events</wa-button>
            <wa-button href="/admin/purchases" variant="{{ active == 'purchases' ? 'primary' : 'neutral' }}" size="s">Purchases</wa-button>
            <wa-button href="/admin/checkin" variant="{{ active == 'checkin' ? 'primary' : 'neutral' }}" size="s">Check-In</wa-button>
            <wa-button href="/admin/audit-logs" variant="{{ active == 'audit' ? 'primary' : 'neutral' }}" size="s">Audit Log</wa-button>
            <wa-button href="/admin/lockouts" variant="{{ active == 'lockouts' ? 'primary' : 'neutral' }}" size="s">Lockouts</wa-button>
            <wa-button href="/admin/admins" variant="{{ active == 'admins' ? 'primary' : 'neutral' }}" size="s">Admins</wa-button>
          </div>
        </wa-card>
      </nav>

      <div class="admin-content">
        {% block admin_content %}{% endblock %}
      </div>
    </div>
  </div>
{% endblock %}
