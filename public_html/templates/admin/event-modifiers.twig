{% extends "admin/layout.twig" %}

{% set active = 'events' %}

{% block admin_content %}
  <wa-card class="admin-card">
    <div class="admin-header-row">
      <div>
        <div class="admin-title">Modifiers</div>
        <div class="admin-subtitle">{{ event.name }}</div>
      </div>
      <div class="admin-actions-row">
        <wa-button href="/admin/events/{{ event.id }}" variant="neutral">Back</wa-button>
        <wa-button href="/admin/events/{{ event.id }}/modifiers/new" variant="primary">New Modifier</wa-button>
      </div>
    </div>

    <div class="admin-table-wrap admin-table-wrap--responsive">
      <table class="admin-table admin-table--responsive">
        <thead>
          <tr>
            <th>Name</th>
            <th>Type</th>
            <th>Required</th>
            <th>Sort</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for row in modifiers %}
            <tr>
              <td data-label="Name">{{ row.name }}</td>
              <td data-label="Type" class="mono">{{ row.modifier_type }}</td>
              <td data-label="Required" class="mono">{{ row.is_required ? 'yes' : 'no' }}</td>
              <td data-label="Sort" class="mono">{{ row.sort_order }}</td>
              <td data-label="Actions"><wa-button href="/admin/events/{{ event.id }}/modifiers/{{ row.id }}" variant="neutral" size="s">Edit</wa-button></td>
            </tr>
          {% else %}
            <tr><td colspan="5">No modifiers yet.</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </wa-card>
{% endblock %}
