{% extends "admin/layout.twig" %}

{% set active = 'audit' %}

{% block admin_content %}
  <wa-card class="admin-card">
    <div class="admin-title">Audit Log</div>
    <p>Most recent events (newest first).</p>

    <div class="admin-table-wrap admin-table-wrap--responsive">
      <table class="admin-table admin-table--responsive">
        <thead>
          <tr>
            <th>Time</th>
            <th>Type</th>
            <th>Admin</th>
            <th>IP</th>
            <th>Message</th>
          </tr>
        </thead>
        <tbody>
          {% for row in logs %}
            <tr>
              <td data-label="Time" class="mono">{{ row.created_at|format_dt_utc('Y-m-d H:i') }}</td>
              <td data-label="Type"><wa-tag size="s">{{ row.event_type }}</wa-tag></td>
              <td data-label="Admin" class="mono">{{ row.admin_id ?? '' }}</td>
              <td data-label="IP" class="mono">{{ row.ip ?? '' }}</td>
              <td data-label="Message">{{ row.message ?? '' }}</td>
            </tr>
          {% else %}
            <tr>
              <td colspan="5">No audit log entries yet.</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </wa-card>
{% endblock %}
