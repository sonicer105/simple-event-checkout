{% extends "admin/layout.twig" %}

{% set active = 'purchases' %}

{% block admin_content %}
  <wa-card class="admin-card">
    <div class="admin-title">Purchases</div>
    <p>Most recent purchases (newest first).</p>

    <form method="get" class="wa-cluster wa-gap-s wa-align-items-end" style="margin: 12px 0 14px; flex-wrap: wrap;">
      <wa-select name="event_id" label="Event Filter">
        <wa-option value="" {% if (filter_event_id ?? 0) == 0 %}selected{% endif %}>All events</wa-option>
        {% for e in events ?? [] %}
          <wa-option value="{{ e.id }}" {% if (filter_event_id ?? 0) == e.id %}selected{% endif %}>{{ e.name }}</wa-option>
        {% endfor %}
      </wa-select>
      <div class="wa-align-self-end" style="padding-bottom: 4px;">
        <wa-checkbox name="include_pending" value="1" {% if include_pending %}checked{% endif %}>Include pending</wa-checkbox>
      </div>
      <wa-button type="submit" variant="neutral">Apply</wa-button>
    </form>

    <div class="admin-table-wrap admin-table-wrap--responsive">
      <table class="admin-table admin-table--responsive">
        <thead>
          <tr>
            <th>Purchase</th>
            <th>Created</th>
            <th>Status</th>
            <th>Email</th>
            <th>Total</th>
          </tr>
        </thead>
        <tbody>
          {% for row in purchases %}
            <tr>
              <td data-label="Purchase">
                <a class="wa-link" href="/admin/purchases/{{ row.id }}">#{{ row.id }}</a>
              </td>
              <td data-label="Created" class="mono">{{ row.created_at|format_dt_utc('Y-m-d H:i') }}</td>
              <td data-label="Status"><wa-tag size="s">{{ row.payment_status }}</wa-tag></td>
              <td data-label="Email" class="mono">{{ row.email }}</td>
              <td data-label="Total" class="mono">{{ (row.total_cents ?? 0)|format_money }} {{ row.currency ?? '' }}</td>
            </tr>
          {% else %}
            <tr>
              <td colspan="5">
                <wa-callout variant="neutral">No purchases yet.</wa-callout>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </wa-card>
{% endblock %}
