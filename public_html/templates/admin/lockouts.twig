{% extends "admin/layout.twig" %}

{% set active = 'lockouts' %}

{% block admin_content %}
  <wa-card class="admin-card">
    <div class="admin-title">Lockouts</div>
    <p>IP-based admin login lockouts. Clearing removes the ban and attempt counter.</p>

    <div class="admin-table-wrap admin-table-wrap--responsive">
      <table class="admin-table admin-table--responsive">
        <thead>
          <tr>
            <th>IP</th>
            <th>Attempts</th>
            <th>Banned Until</th>
            <th>Last Attempt</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for row in lockouts %}
            <tr>
              <td data-label="IP" class="mono">{{ row.ip }}</td>
              <td data-label="Attempts" class="mono">{{ row.attempts }}</td>
              <td data-label="Banned Until" class="mono">{{ row.banned_until ?? '' }}</td>
              <td data-label="Last Attempt" class="mono">{{ row.last_attempt_at }}</td>
              <td>
                <form method="post" action="/admin/lockouts/clear">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                  <input type="hidden" name="ip" value="{{ row.ip }}" />
                  <wa-button type="submit" variant="neutral" size="s">Clear</wa-button>
                </form>
              </td>
            </tr>
          {% else %}
            <tr>
              <td colspan="5">No lockouts.</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </wa-card>
{% endblock %}
