{% extends "base.twig" %}

{% block content %}
  <div class="auth-card">
    <wa-card class="auth-panel">
      <div class="auth-header">
        <div class="auth-title">Two-Factor Required</div>
        <div class="auth-subtitle">Enter the code from your authenticator app.</div>
      </div>

      {% if error %}
        <wa-callout variant="danger" class="auth-callout">{{ error }}</wa-callout>
      {% endif %}

      <form method="post" action="/admin/2fa" class="auth-form">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
        <wa-input name="code" label="Authentication Code" inputmode="numeric" autocomplete="one-time-code" required></wa-input>
        <wa-button type="submit" variant="primary">Verify</wa-button>
      </form>
    </wa-card>
  </div>
{% endblock %}
