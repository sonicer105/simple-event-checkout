{% extends "admin/layout.twig" %}

{% set active = 'events' %}

{% block admin_content %}
  <wa-card class="admin-card">
    <div class="admin-header-row">
      <div>
        <div class="admin-title">{{ is_new ? 'New Add-on' : 'Edit Add-on' }}</div>
        <div class="admin-subtitle">{{ event.name }}</div>
      </div>
      <wa-button href="/admin/events/{{ event.id }}/addons" variant="neutral">Back</wa-button>
    </div>

    {% if error %}
      <wa-callout variant="danger" class="auth-callout">{{ error }}</wa-callout>
    {% endif %}

    <form method="post" class="admin-form">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
      <wa-input name="name" label="Name" value="{{ addon.name ?? '' }}" required></wa-input>
      <wa-textarea name="short_description" label="Short Description" value="{{ addon.short_description ?? '' }}" required></wa-textarea>

      <div class="admin-form-row">
        <wa-input type="number" name="price_cents" label="Price (cents)" value="{{ addon.price_cents ?? '' }}"></wa-input>
        <wa-input type="number" name="stock_limit" label="Stock Limit" value="{{ addon.stock_limit ?? '' }}"></wa-input>
      </div>

      <wa-button type="submit" variant="primary">{{ is_new ? 'Create Add-on' : 'Save Changes' }}</wa-button>
    </form>
  </wa-card>
{% endblock %}

