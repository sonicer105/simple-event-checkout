{% extends "admin/layout.twig" %}

{% set active = 'events' %}

{% block admin_content %}
  <wa-card class="admin-card">
    <div class="admin-header-row">
      <div>
        <div class="admin-title">{{ is_new ? 'New Event' : 'Edit Event' }}</div>
        <div class="admin-subtitle">{{ is_new ? 'Create a new event ticket.' : 'Update event details and publishing status.' }}</div>
      </div>
      <wa-button href="/admin/events" variant="neutral">Back</wa-button>
    </div>

    {% if error %}
      <wa-callout variant="danger" class="auth-callout">{{ error }}</wa-callout>
    {% endif %}

    <form method="post" class="admin-form">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
      <wa-input name="name" label="Name" value="{{ event.name ?? '' }}" required></wa-input>
      <wa-input name="slug" label="Slug" help-text="Used in the URL. Lowercase letters, numbers, and dashes recommended." value="{{ event.slug ?? '' }}" required></wa-input>
      <wa-textarea name="short_description" label="Short Description" value="{{ event.short_description ?? '' }}" required></wa-textarea>

      <wa-textarea name="long_description" label="Long Description (Markdown)" value="{{ event.long_description ?? '' }}"></wa-textarea>

      <wa-select name="image_path" label="Image">
        <wa-option value="" {% if (event.image_path ?? '') == '' %}selected{% endif %}>(none)</wa-option>
        {% for p in image_options %}
          {% set fname = p|split('/')|last %}
          <wa-option value="{{ p }}" {% if (event.image_path ?? '') == p %}selected{% endif %}>{{ fname }}</wa-option>
        {% endfor %}
      </wa-select>

      <div class="admin-form-row">
        <wa-input name="location" label="Location" value="{{ event.location ?? '' }}"></wa-input>
        <wa-select name="status" label="Status" required>
          {% for s in statuses %}
            <wa-option value="{{ s }}" {% if (event.status ?? 'draft') == s %}selected{% endif %}>{{ s }}</wa-option>
          {% endfor %}
        </wa-select>
      </div>

      <div class="admin-form-row">
        <wa-input type="datetime-local" name="start_time" label="Start Time" value="{{ event.start_time_local ?? '' }}"></wa-input>
        <wa-input type="datetime-local" name="end_time" label="End Time" value="{{ event.end_time_local ?? '' }}"></wa-input>
      </div>

      <div class="admin-form-row">
        <wa-input type="number" name="price_cents" label="Price (cents)" value="{{ event.price_cents ?? '' }}"></wa-input>
        <wa-input type="number" name="stock_limit" label="Stock Limit" value="{{ event.stock_limit ?? '' }}"></wa-input>
      </div>

      <wa-divider></wa-divider>

      <wa-button type="submit" variant="primary">{{ is_new ? 'Create Event' : 'Save Changes' }}</wa-button>
    </form>

    {% if not is_new %}
      <wa-divider></wa-divider>

      <wa-details>
        <div slot="summary" class="wa-body-m"><strong>Stock Overview</strong></div>
        <div class="wa-caption-s" style="margin: 6px 0 10px; color: var(--wa-color-neutral-700);">
          Sold = paid, non-refunded. Held = active carts (last activity within ~1 hour). Stock limit of 0 means unlimited.
        </div>

        <div class="wa-caption-s" style="margin: 0 0 6px; color: var(--wa-color-neutral-700);"><strong>Tickets</strong></div>
        <div class="admin-table-wrap admin-table-wrap--responsive" style="margin-bottom: 10px;">
          <table class="admin-table admin-table--responsive">
            <thead>
              <tr>
                <th>Ticket</th>
                <th>Limit</th>
                <th>Sold</th>
                <th>Held</th>
                <th>Available</th>
              </tr>
            </thead>
            <tbody>
              {% for s in stock_overview ?? [] %}
                <tr>
                  <td data-label="Ticket">{{ s.label }}</td>
                  <td data-label="Limit" class="mono">{{ s.stock_limit is null ? 'unlimited' : s.stock_limit }}</td>
                  <td data-label="Sold" class="mono">{{ s.sold }}</td>
                  <td data-label="Held" class="mono">{{ s.held }}</td>
                  <td data-label="Available" class="mono">{{ s.available is null ? 'unlimited' : s.available }}</td>
                </tr>
              {% else %}
                <tr><td colspan="5">No stock data.</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>

        {% if addon_stock_overview is defined and addon_stock_overview|length > 0 %}
          <div class="wa-caption-s" style="margin: 2px 0 6px; color: var(--wa-color-neutral-700);"><strong>Add-ons</strong></div>
          <div class="admin-table-wrap admin-table-wrap--responsive" style="margin-bottom: 10px;">
            <table class="admin-table admin-table--responsive">
              <thead>
                <tr>
                  <th>Add-on</th>
                  <th>Limit</th>
                  <th>Sold</th>
                  <th>Held</th>
                  <th>Available</th>
                </tr>
              </thead>
              <tbody>
                {% for a in addon_stock_overview %}
                  <tr>
                    <td data-label="Add-on">{{ a.label }}</td>
                    <td data-label="Limit" class="mono">{{ a.stock_limit is null ? 'unlimited' : a.stock_limit }}</td>
                    <td data-label="Sold" class="mono">{{ a.sold }}</td>
                    <td data-label="Held" class="mono">{{ a.held }}</td>
                    <td data-label="Available" class="mono">{{ a.available is null ? 'unlimited' : a.available }}</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% endif %}
      </wa-details>

      <div class="admin-section-title">Event Options</div>
      <div class="admin-actions-row">
        <wa-button href="/admin/events/{{ event.id }}/variations" variant="neutral">Variations</wa-button>
        <wa-button href="/admin/events/{{ event.id }}/modifiers" variant="neutral">Modifiers</wa-button>
        <wa-button href="/admin/events/{{ event.id }}/addons" variant="neutral">Add-ons</wa-button>
      </div>
    {% endif %}
  </wa-card>
{% endblock %}
