<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ app.app_name }} 2FA Code</title>
    <style>
      body {
        margin: 0;
        background: #f4f4f2;
        font-family: Arial, sans-serif;
        color: #1c1c1c;
      }
      .wrapper {
        padding: 32px 16px;
      }
      .card {
        max-width: 520px;
        margin: 0 auto;
        background: #ffffff;
        padding: 24px;
        border-radius: 12px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
      }
      .title {
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 12px;
      }
      .code {
        font-size: 28px;
        letter-spacing: 0.2em;
        font-weight: 700;
        background: #f1f1ef;
        padding: 12px 16px;
        border-radius: 10px;
        text-align: center;
        margin: 16px 0;
      }
      .meta {
        color: #666666;
        font-size: 13px;
        line-height: 1.5;
      }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <div class="card">
        <div class="title">Your {{ app.app_name }} sign-in code</div>
        <div class="code">{{ code }}</div>
        <div class="meta">
          This code expires in {{ expires_minutes }} minutes. If you did not request this, you can ignore this email.
        </div>
      </div>
    </div>
  </body>
</html>
